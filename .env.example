# Required
PRODUCTBOARD_API_KEY=your_productboard_api_key_here
STORAGE_BACKEND=local   # local | onedrive | sharepoint

# Local backend
LOCAL_OUTPUT_DIR=/path/to/output/folder

# OneDrive backend (app-only auth via client credentials)
# ONEDRIVE_TENANT_ID=your-azure-tenant-id
# ONEDRIVE_CLIENT_ID=your-azure-app-client-id
# ONEDRIVE_CLIENT_SECRET=your-azure-app-client-secret
# ONEDRIVE_DRIVE_ID=the-onedrive-drive-id
# ONEDRIVE_FOLDER_ID=the-onedrive-folder-item-id

# SharePoint backend
# ONEDRIVE_TENANT_ID=your-azure-tenant-id
# ONEDRIVE_CLIENT_ID=your-azure-app-client-id
# ONEDRIVE_CLIENT_SECRET=your-azure-app-client-secret
# SHAREPOINT_SITE_ID=your-sharepoint-site-id
# SHAREPOINT_DRIVE_ID=your-sharepoint-drive-id
# SHAREPOINT_FOLDER_ID=your-sharepoint-folder-item-id

# Optional
SYNC_ENTITIES=all   # comma-separated entity types or "all"
LOG_LEVEL=INFO      # DEBUG | INFO | WARNING | ERROR
# REQUEST_TIMEOUT=30  # HTTP request timeout in seconds (applies to all API calls)
